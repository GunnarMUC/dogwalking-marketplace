# ==========================================
# DogWalking Web Backend - Environment Variables
# ==========================================
#
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control
#

# ==========================================
# REQUIRED VARIABLES
# ==========================================

# Database Connection
# Example: postgresql://user:password@host.region.neon.tech/dbname
DATABASE_URL=postgresql://user:password@host:5432/dogwalking

# Authentication Secret
# Generate a secure random string (min 32 characters)
# You can use: openssl rand -base64 32
AUTH_SECRET=your-super-secure-random-string-at-least-32-characters-long

# Trust the host for auth (required for production)
AUTH_TRUST_HOST=true

# ==========================================
# OPTIONAL VARIABLES
# ==========================================

# File Upload Service (Uploadcare)
# Get your key from: https://uploadcare.com/
UPLOADCARE_PUBLIC_KEY=demopublickey

# Google Maps API
# Get your key from: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ==========================================
# DEVELOPMENT VARIABLES
# ==========================================

# Environment mode
NODE_ENV=development

# CORS Origins (comma-separated list)
# Required for production to allow your frontend domains
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ==========================================
# CREATE.XYZ INTEGRATION (Optional)
# ==========================================
# These are only needed if you're using Create.xyz services

# NEXT_PUBLIC_CREATE_BASE_URL=https://www.create.xyz
# NEXT_PUBLIC_CREATE_HOST=your-host
# NEXT_PUBLIC_PROJECT_GROUP_ID=your-project-id

# ==========================================
# PRODUCTION CHECKLIST
# ==========================================
#
# Before deploying to production, ensure:
# ✅ DATABASE_URL points to production database
# ✅ AUTH_SECRET is a strong random string (32+ chars)
# ✅ AUTH_TRUST_HOST is set to true
# ✅ NODE_ENV is set to 'production'
# ✅ All API keys are production keys
# ✅ CORS_ORIGINS is configured for your domains
#
